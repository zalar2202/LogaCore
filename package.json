{
  "name": "logacore",
  "version": "1.0.0",
  "description": "LogaCore Monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write .",
    "type-check": "pnpm -r type-check",
    "deploy": "pnpm -r build",
    "db:dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:dev:down": "docker compose -f docker-compose.dev.yml stop",
    "db:dev:reset": "docker compose -f docker-compose.dev.yml down -v",
    "db:check": "node scripts/check-db.js",
    "db:migrate": "tsx packages/core/src/migrations/runner.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "esbuild", "sharp", "unrs-resolver"]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}