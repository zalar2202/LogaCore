{
  "name": "logacore",
  "version": "1.0.0",
  "description": "LogaCore Monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write .",
    "type-check": "pnpm -r type-check",
    "deploy": "pnpm -r build",
    "db:dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:dev:down": "docker compose -f docker-compose.dev.yml stop",
    "db:dev:reset": "docker compose -f docker-compose.dev.yml down -v",
    "db:check": "node scripts/check-db.js",
    "db:migrate": "tsx packages/core/src/migrations/runner.ts",
    "db:seed-admin": "tsx scripts/seed-admin.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "drizzle-orm": "^0.45.1",
      "@trpc/server": "^11.10.0",
      "@trpc/client": "^11.10.0",
      "@trpc/react-query": "^11.10.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.34",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "pg": "^8.19.0"
  }
}