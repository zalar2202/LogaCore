{
  "name": "@logacore/core",
  "version": "0.1.0",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./trpc": "./src/trpc/index.ts",
    "./auth": "./src/auth/index.ts",
    "./server": "./server.ts"
  },
  "scripts": {
    "build": "tsc",
    "build:migrations": "tsc src/migrations/runner.ts --outDir dist/migrations --esModuleInterop --module CommonJS --target ES2020",
    "bundle:migrations": "esbuild src/migrations/runner.ts --bundle --platform=node --target=node20 --outfile=dist/migrations/runner.bundle.js",
    "dev": "tsc -w",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "drizzle-orm": "^0.45.1",
    "esbuild": "^0.27.3",
    "react": "^19",
    "zod": "^3.25.76"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@logacore/db": "workspace:*",
    "@trpc/server": "^11.10.0",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "next-auth": "5.0.0-beta.30",
    "pg": "^8.19.0"
  }
}