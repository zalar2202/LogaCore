{
  "name": "@logacore/core",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./trpc": {
      "types": "./dist/src/trpc/index.d.ts",
      "default": "./dist/src/trpc/index.js"
    },
    "./auth": {
      "types": "./dist/src/auth/index.d.ts",
      "default": "./dist/src/auth/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:migrations": "tsc src/migrations/runner.ts --outDir dist/migrations --esModuleInterop --module CommonJS --target ES2020",
    "dev": "tsc -w",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@trpc/server": "^11.10.0",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "next-auth": "5.0.0-beta.30",
    "pg": "^8.19.0",
    "zod": "^4.3.6"
  }
}