# Coolify Postgres DB Connection String Example
# Replace the placeholders with your actual secure values generated by Coolify
DATABASE_URL="postgresql://postgres:password@host:5432/logacore?schema=public"

# Next Auth (Auth.js) environment variables
# NEXTAUTH_URL="https://logatech.cloud"
NEXTAUTH_SECRET="generate-a-strong-secret-using-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="https://logatech.cloud"
